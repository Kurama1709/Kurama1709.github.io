---
import { site } from '../data/site.js';
const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="container footer__inner">
    <span class="footer__mark">{site.name}</span>
    <span class="footer__role">{site.role}</span>
    <span class="footer__copy">© {year}. All rights reserved.</span>
  </div>
</footer>

<style>
  .footer { border-top: 1px solid var(--color-line); padding-block: var(--space-xl); }
  .footer__inner {
    display: flex; flex-wrap: wrap; align-items: baseline; gap: var(--space-sm) var(--space-md);
  }
  .footer__mark { font-family: var(--font-display); font-size: var(--step-1); }
  .footer__role { font-size: var(--step--1); letter-spacing: var(--tracking-wide); text-transform: uppercase; color: var(--color-text-muted); }
  .footer__copy { margin-left: auto; font-size: var(--step--1); color: var(--color-text-faint); }
</style>
