---
---
<div class="lb" data-lightbox hidden>
  <div class="lb__backdrop" data-lb-close></div>
  <div class="lb__dialog" role="dialog" aria-modal="true" aria-label="Video player" tabindex="-1">
    <button class="lb__close" data-lb-close aria-label="Close">
      <svg width="22" height="22" viewBox="0 0 22 22" fill="none" aria-hidden="true">
        <path d="M5 5l12 12M17 5L5 17" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
      </svg>
    </button>
    <button class="lb__nav lb__nav--prev" data-lb-prev aria-label="Previous in this series" hidden>
      <svg width="22" height="22" viewBox="0 0 22 22" fill="none" aria-hidden="true"><path d="M14 4l-7 7 7 7" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
    </button>
    <button class="lb__nav lb__nav--next" data-lb-next aria-label="Next in this series" hidden>
      <svg width="22" height="22" viewBox="0 0 22 22" fill="none" aria-hidden="true"><path d="M8 4l7 7-7 7" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
    </button>
    <div class="lb__stage" data-lb-stage></div>
    <div class="lb__caption" data-lb-caption>
      <h3 class="lb__title" data-lb-title></h3>
      <p class="lb__meta" data-lb-meta></p>
      <p class="lb__blurb prose" data-lb-blurb></p>
      <p class="lb__series" data-lb-series hidden></p>
    </div>
  </div>
</div>

<style>
  .lb {
    position: fixed; inset: 0; z-index: var(--z-lightbox);
    display: grid; place-items: center; padding: var(--gutter);
  }
  .lb[hidden] { display: none; }
  .lb__backdrop {
    position: absolute; inset: 0; background: var(--color-overlay);
    -webkit-backdrop-filter: blur(8px); backdrop-filter: blur(8px);
    opacity: 0; transition: opacity var(--dur) var(--ease);
  }
  .lb.is-open .lb__backdrop { opacity: 1; }

  .lb__dialog {
    position: relative; z-index: 1;
    width: min(100%, 1100px); max-height: 92svh;
    display: flex; flex-direction: column; gap: var(--space-md);
    opacity: 0; transform: translateY(12px) scale(0.99);
    transition: opacity var(--dur) var(--ease), transform var(--dur) var(--ease);
  }
  .lb.is-open .lb__dialog { opacity: 1; transform: none; }

  .lb__close {
    position: absolute; top: -2.6rem; right: 0; color: var(--color-text-muted);
    width: 40px; height: 40px; display: grid; place-items: center; border-radius: var(--radius-pill);
    transition: color var(--dur) var(--ease), background var(--dur) var(--ease);
  }
  .lb__close:hover, .lb__close:focus-visible { color: var(--color-text); background: var(--color-bg-elev); }

  /* Prev / next within a same-shoot series */
  .lb__nav {
    position: absolute; top: 38%; translate: 0 -50%; z-index: 3;
    width: 46px; height: 46px; display: grid; place-items: center; color: var(--color-text);
    background: color-mix(in srgb, var(--color-bg-elev) 72%, transparent); border-radius: var(--radius-pill);
    -webkit-backdrop-filter: blur(8px); backdrop-filter: blur(8px);
    transition: background var(--dur) var(--ease), color var(--dur) var(--ease);
  }
  .lb__nav[hidden] { display: none; }
  .lb__nav:hover, .lb__nav:focus-visible { background: var(--color-text); color: #0a0a0a; }
  .lb__nav--prev { left: -10px; }
  .lb__nav--next { right: -10px; }
  .lb__series { font-size: var(--step--1); color: var(--color-text-faint); letter-spacing: 0.08em; margin-top: var(--space-2xs); }
  .lb__series[hidden] { display: none; }
  @media (max-width: 40rem) {
    .lb__nav { top: auto; bottom: -2.95rem; }
    .lb__nav--prev { left: 22%; right: auto; }
    .lb__nav--next { right: 22%; left: auto; }
  }

  .lb__stage {
    position: relative; background: #000;
    border-radius: var(--radius-md); overflow: hidden;
    align-self: center;                 /* don't let the column-flex stretch it */
    width: 100%; max-width: 100%;
    aspect-ratio: var(--lb-aspect, 16 / 9);
    max-height: 76svh;
  }
  /* Portrait clips: drive size from height so the tall video actually has a box. */
  .lb__stage.is-portrait {
    width: auto;
    height: min(76svh, 78vh);
    aspect-ratio: var(--lb-aspect, 9 / 16);
  }

  .lb__stage :global(video),
  .lb__stage :global(iframe) {
    position: absolute; inset: 0; width: 100%; height: 100%; border: 0;
  }
  .lb__stage :global(.lb__placeholder) {
    position: absolute; inset: 0; background-size: cover; background-position: center;
    display: grid; place-items: center;
  }
  .lb__stage :global(.lb__placeholder)::before {
    content: ''; position: absolute; inset: 0; background: rgba(6,6,6,0.62);
  }
  .lb__stage :global(.lb__phnote) {
    position: relative; font-family: var(--font-display); font-size: var(--step-1);
    color: var(--color-text); letter-spacing: 0.01em;
  }
  .lb__stage :global(.lb__unmute) {
    position: absolute; left: 50%; bottom: 14%; translate: -50% 0; z-index: 2;
    display: inline-flex; align-items: center; gap: var(--space-xs);
    padding: var(--space-xs) var(--space-md);
    font-size: var(--step--1); letter-spacing: 0.04em; color: #0a0a0a;
    background: var(--color-text); border-radius: var(--radius-pill);
    box-shadow: var(--shadow-soft); animation: unmute-in var(--dur) var(--ease);
  }
  @keyframes unmute-in { from { opacity: 0; transform: translateY(6px); } to { opacity: 1; } }

  .lb__caption { padding-inline: var(--space-2xs); }
  .lb__title { font-size: var(--step-2); }
  .lb__meta { font-size: var(--step--1); color: var(--color-text-muted); letter-spacing: 0.04em; margin-top: var(--space-2xs); }
  .lb__blurb { margin-top: var(--space-sm); }

  @media (max-width: 40rem) {
    .lb__close { top: auto; bottom: -2.8rem; right: 50%; transform: translateX(50%); }
  }
</style>
